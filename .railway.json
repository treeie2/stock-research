{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "cache": false
  },
  "deploy": {
    "startCommand": "gunicorn main:app --bind 0.0.0.0:$PORT && echo 'DEPLOYED_AT: $(date -u)'",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10,
    "healthcheckPath": "/",
    "healthcheckTimeout": 100
  }
}
